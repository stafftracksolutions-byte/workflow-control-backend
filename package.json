{
  "name": "workflow-control-backend",
  "version": "1.0.0",
  "description": "API backend para el sistema WORKFLOW CONTROL (gestión de empleados).",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test:mongo": "jest tests/mongo.test.js --verbose --runInBand",
    "test:superadmin": "jest tests/superadmin.test.js --verbose --runInBand",
    "test:admin": "jest tests/admin.test.js --verbose --runInBand",
    "test:empleado": "jest tests/empleado.test.js --verbose --runInBand",
    "test:jwt": "jest tests/jwt.test.js --verbose --runInBand",
    "test:all": "npm run test:mongo && npm run test:jwt",
    "lint": "eslint . --ext .js,.mjs,.cjs",
    "lint:fix": "eslint . --fix",
    "seed:usuarios": "node seeds/seedUsuariosMongo.js",
    "seed:empleados": "node seeds/seedEmpleadosMongo.js",
    "seed:mongo": "node seeds/seedMongo.js",
    "seed:superadmin": "node seeds/seedSuperadminJWT.js",
    "seed:admin": "node seeds/seedAdminJWT.js",
    "seed:empleadojwt": "node seeds/seedEmpleadoJWT.js",
    "seed:jwt": "node seeds/seedJWT.js",
    "seed:BDEmployees": "node seeds/seedAdminJWTCreateEmployees.js",
    "seed:superadmin-empleado": "node seeds/seedSuperadminEmpleadoJWT.js",
    "seed:admin-empleado": "node seeds/seedAdminEmpleadoJWT.js",
    "seed:all": "npm run seed:mongo && npm run seed:jwt"
  },
  "keywords": [
    "backend",
    "api",
    "nodejs",
    "express",
    "workflow",
    "empleados"
  ],
  "author": "Melkin Andres Villamil Melo",
  "license": "UNLICENSED",
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.2",
    "morgan": "^1.10.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-pretty": "^6.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "jest": "^30.1.3",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4"
  }
}
